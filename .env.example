PORT=5500
HOST=127.0.0.1

FRONTEND_ORIGINS=https://your-frontend-domain.tld
ADMIN_PASSWORD=replace-with-long-random-admin-password

# OpenWebUI — OpenAI-compatible API (competition docs §5).
# Base URL (same as OpenAI Python: OpenAI(base_url="https://ai.cyberlab.csusb.edu/api", ...)).
AI_BASE_URL=https://ai.cyberlab.csusb.edu/api
# Optional: override full endpoint; default is AI_BASE_URL + /chat/completions
# AI_API_URL=https://ai.cyberlab.csusb.edu/api/chat/completions
# Authorization: Bearer <key> (401 if wrong; 403 if model not allowed; 404 if URL/model wrong; 429 if rate limited).
AI_API_KEY=replace-with-your-api-key
# Must match an allowed model name from the competition spreadsheet (404 if wrong).
AI_MODEL=MODEL_NAME

DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=bottleops_store
DB_USER=storeapp
DB_PASSWORD=replace-with-db-password
DB_SSL=false

SMTP_HOST=smtp.yourdomain.tld
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=no-reply@yourdomain.tld

MAX_JSON_BODY_BYTES=65536
